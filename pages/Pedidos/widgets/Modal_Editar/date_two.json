  "defaultDate": "{{\n(() => {\n  // 1. Si el usuario ya capturó algo y está en el store temporal, mostrar eso\n  const temp = appsmith.store?.fecha_fin_temp;\n  if (temp) return temp;\n\n  // 2. Si no hay temporal, usar la lógica original de cliente_edit_row\n  const v = appsmith.store?.cliente_edit_row?.fecha_fin;\n  if (!v) return \"\";\n\n  // Intento de parsear fecha original\n  var d = new Date(v);\n  if (!isNaN(d.getTime())) {\n    var yyyy = d.getFullYear();\n    var mm = String(d.getMonth() + 1).padStart(2, \"0\");\n    var dd = String(d.getDate()).padStart(2, \"0\");\n    return yyyy + \"-\" + mm + \"-\" + dd;\n  }\n\n  return \"\";\n})()\n}}",
